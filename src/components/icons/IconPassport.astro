---
interface Props {
  class?: string;
}
const { class: className = 'h-6 w-6' } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <rect x="5" y="3" width="14" height="18" rx="2"></rect>
  <circle cx="12" cy="10" r="3"></circle>
  <path d="M9 16h6"></path>
</svg>
